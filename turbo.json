{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": ["coverage/**"]
    },
    "lint": {
      "dependsOn": []
    },
    "format:check": {
      "dependsOn": []
    },
    "typecheck": {
      "dependsOn": []
    },
    "validate": {
      "dependsOn": ["build"]
    },
    "size": {
      "dependsOn": ["build"]
    }
  }
}
